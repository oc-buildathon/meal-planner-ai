# === Deep Agent (primary — powered by deepagents) ===
# Model in "provider:model" format. The provider's API key env var must be set below.
# Examples: "openai:gpt-4o", "anthropic:claude-sonnet-4-6", "google-genai:gemini-2.5-pro"
AGENT_MODEL=openai:gpt-4o

# Provider API keys (set the one matching your AGENT_MODEL provider)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AI...

# === LLM fallback (OpenAI-compatible endpoint, used if agent is not initialized) ===
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# === WhatsApp (Baileys) ===
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_ID=mealprep-bot
WHATSAPP_AUTH_DIR=./auth_sessions
# Option 1: Leave empty for QR code pairing (scan with phone camera)
# Option 2: Set your phone number for pairing code (e.g. 919876543210, no + prefix)
WHATSAPP_PHONE_NUMBER=

# === Telegram ===
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# === LangSmith (optional — tracing & observability) ===
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=

# === Server ===
PORT=3000
