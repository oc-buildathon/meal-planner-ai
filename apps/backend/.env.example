# === LLM (OpenAI-compatible endpoint) ===
# Point to any OpenAI-compatible API: OpenAI, OpenRouter, Ollama, vLLM, LiteLLM, etc.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7

# === WhatsApp (Baileys) ===
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_ID=mealprep-bot
WHATSAPP_AUTH_DIR=./auth_sessions
# Option 1: Leave empty for QR code pairing (scan with phone camera)
# Option 2: Set your phone number for pairing code (e.g. 919876543210, no + prefix)
WHATSAPP_PHONE_NUMBER=

# === Telegram ===
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# === Server ===
PORT=3000
